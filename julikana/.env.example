# ── Core ────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000

# ── Database & cache ────────────────────────────────────────────────
DATABASE_URL=postgresql://julikana:julikana@localhost:5432/julikana
REDIS_URL=redis://localhost:6379

# ── Auth ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-64-random-bytes
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
TWO_FACTOR_ISSUER=Julikana

# ── Storage (choose one driver: s3 | supabase) ──────────────────────
STORAGE_DRIVER=s3
S3_BUCKET=julikana-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=media

# ── AI providers ────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=
FLUX_API_KEY=
STABILITY_API_KEY=
RUNWAY_API_KEY=
HIGGSFIELD_API_KEY=
PIKA_API_KEY=
ELEVENLABS_API_KEY=

# ── Social platforms (OAuth apps) ───────────────────────────────────
META_APP_ID=
META_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_API_KEY=
X_API_SECRET=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Billing ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=

# ── Platform ownership (connector management) ───────────────────────
# Comma-separated emails allowed to add/enable connectors. ONLY these
# accounts can manage integrations — regular users never can.
SUPERADMIN_EMAILS=microcitytech@gmail.com

# ── M-Pesa (Safaricom Daraja) — for boosts/ad spend, no card storage ─
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=

# ── Web (Next.js) ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
